    <style name="ThemeOverlay.UPROXConcierge.ActionBar" parent="ThemeOverlay.AppCompat.ActionBar">
        <item name="android:textColorPrimary">@color/white</item>
    </style>
    <style name="Theme.UPROXConcierge" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="colorSurface">@color/primary</item>
        <item name="colorOnSurface">@color/white</item>

        <item name="actionBarTheme">@style/ThemeOverlay.UPROXConcierge.ActionBar</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/primary_variant</item>
    </style>
</resources>

